{
  "name": "daily-schedule",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsdown && cp src/manifest.json src/styles.css dist/",
    "check": "pnpm format:check && pnpm lint",
    "deploy": "scripts/deploy.sh",
    "dev": "cp src/manifest.json src/styles.css dist/ && tsdown --watch",
    "fix": "pnpm lint:fix && pnpm format",
    "format": "oxfmt",
    "format:check": "pnpm format --check",
    "lint": "oxlint",
    "lint:fix": "pnpm lint --fix --fix-suggestions",
    "lint:fixall": "pnpm lint:fix --fix-dangerously"
  },
  "devDependencies": {
    "ical.js": "^2.2.1",
    "moment": "2.29.4",
    "obsidian": "^1.12.3",
    "oxfmt": "latest",
    "oxlint": "latest",
    "oxlint-tsgolint": "latest",
    "tsdown": "latest",
    "typescript": "^6"
  },
  "packageManager": "pnpm@11.8.0"
}
