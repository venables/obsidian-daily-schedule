{
  "name": "daily-schedule",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsdown && cp src/manifest.json src/styles.css dist/",
    "check": "bun run format:check && bun run lint",
    "deploy": "scripts/deploy.sh",
    "dev": "cp src/manifest.json src/styles.css dist/ && tsdown --watch",
    "fix": "bun run lint:fix && bun run format",
    "format": "oxfmt",
    "format:check": "bun run format -- --check",
    "lint": "oxlint",
    "lint:fix": "bun run lint -- --fix --fix-suggestions",
    "lint:fixall": "bun run lint:fix -- --fix-dangerously"
  },
  "devDependencies": {
    "ical.js": "^2.2.1",
    "obsidian": "^1.12.3",
    "oxfmt": "latest",
    "oxlint": "latest",
    "oxlint-tsgolint": "latest",
    "tsdown": "latest",
    "typescript": "^6"
  }
}
