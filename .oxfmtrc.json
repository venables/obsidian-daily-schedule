{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "embeddedLanguageFormatting": "auto",
  "semi": false,
  "singleQuote": false,
  "trailingComma": "none",
  "tabWidth": 2,
  "printWidth": 80,
  "proseWrap": "always",
  "sortImports": true,
  "sortPackageJson": {
    "sortScripts": true
  },
  "ignorePatterns": ["main.js", "node_modules"]
}
